{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsxImportSource": "solid-js",
    "jsx": "preserve",
    "strict": true,
    "types": ["vite/client"],
    "paths": {
      "~/*": ["./src/*"]
    },
    "noEmit": true,
    "noUnusedLocals": false,
    "skipLibCheck": true
  }
}
